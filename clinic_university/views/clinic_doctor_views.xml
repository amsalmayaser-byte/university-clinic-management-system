 <odoo>
    <!-- Tree View -->
    <record id="view_clinic_doctor_tree" model="ir.ui.view">
        <field name="name">clinic.doctor.tree</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="doctor_name"/>
                <field name="doctor_code"/>
                <field name="department_id"/>
                <field name="phone"/>
                <field name="email"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_clinic_doctor_form" model="ir.ui.view">
        <field name="name">clinic.doctor.form</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="doctor_name"/>
                        <field name="doctor_code"/>
                    </group>
                    <group>
                        <field name="department_id"/>
                        <field name="specialty_ids"/>
                    </group>
                    <group>
                        <field name="qualification"/>
                        <field name="experience_years"/>
                        <field name="consultation_charge"/>
                    </group>
                    <group>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_clinic_doctor_search" model="ir.ui.view">
        <field name="name">clinic.doctor.search</field>
        <field name="model">clinic.doctor</field>
        <field name="arch" type="xml">
            <search>
                <field name="doctor_name"/>
                <field name="doctor_code"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_clinic_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">clinic.doctor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_clinic_root" name="Clinic"/>
    <menuitem id="menu_clinic_doctor"
              name="Doctors"
              parent="menu_clinic_root"
              action="action_clinic_doctor"/>
</odoo>
